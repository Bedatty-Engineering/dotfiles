# This is Git's per-user configuration file.
[core]
	excludesfile = ~/.gitignore_global
[user]
	name = Your Name
	email = your@email.com
	signingkey = ~/.ssh/company_github_key
# Please adapt and uncomment the following lines:
#	name = Your Name
#	email = your@email.com
[gpg]
	format = ssh
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[url "git@github.com:"]
	insteadOf = https://github.com/
