[default]
region = us-east-1

### Lerian Studio
[sso-session lerian-sso]
sso_start_url = https://<SSO_SUBDOMAIN>.awsapps.com/start#
sso_region = us-east-1
sso_registration_scopes = sso:account:access

[profile lerian]
sso_session = lerian-sso
sso_account_id = <ACCOUNT_ID_LERIAN>
sso_role_name = AWSAdministratorAccess
region = us-east-2
output = json
cli_pager =

[profile lerian-devops]
