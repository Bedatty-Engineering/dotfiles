# ~/.kube/<cluster>-config — NÃO versionar (contém certificados e tokens)
# O .zshrc faz merge automático de todos os arquivos *-config em ~/.kube/
#
# Clusters em uso:
#   alpha-k8s  → <ALPHA_IP>:6443
#   beta-k8s   → <BETA_IP>:6443
#   gamma-k8s  → <GAMMA_IP>:6443
#   delta-k8s  → <DELTA_IP>:6443
#
# Namespaces por contexto:
#   alpha-k8s  → app-dev
#   beta-k8s   → platform-dev
#   gamma-k8s  → monitoring-dev
#   delta-k8s  → platform-dev

apiVersion: v1
kind: Config
current-context: ""
clusters:
  - name: <cluster>-k8s
    cluster:
      server: https://<CLUSTER_IP>:6443
      certificate-authority-data: <BASE64_CA>
contexts:
  - name: <cluster>-k8s
    context:
      cluster: <cluster>-k8s
      user: <cluster>-k8s
      namespace: <namespace>
users:
  - name: <cluster>-k8s
    user:
      client-certificate-data: <BASE64_CERT>
      client-key-data: <BASE64_KEY>
