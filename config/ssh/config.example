# ~/.ssh/config — hosts sensíveis (não versionar)
# Chaves disponíveis em ~/.ssh/:
#   company_github_key / company_github_key.pub  — GitHub da empresa
#   id_ed25519 / id_ed25519.pub                  — chave pessoal
#   gamma.pem                                    — cluster Gamma (AWS)

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/company_github_key

# Clusters Kubernetes (acesso direto)
# Host alpha
#   HostName <ALPHA_IP>
#   User ubuntu
#   IdentityFile ~/.ssh/company_github_key
#
# Host beta
#   HostName <BETA_IP>
#   User ubuntu
#   IdentityFile ~/.ssh/company_github_key
#
# Host gamma
#   HostName <GAMMA_IP>
#   User ubuntu
#   IdentityFile ~/.ssh/gamma.pem
#
# Host delta
#   HostName <DELTA_IP>
#   User ubuntu
#   IdentityFile ~/.ssh/company_github_key
