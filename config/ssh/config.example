# ~/.ssh/config — hosts sensíveis (não versionar)
# Chaves disponíveis em ~/.ssh/:
#   lerian_github_key / lerian_github_key.pub  — GitHub Lerian
#   id_ed25519 / id_ed25519.pub                — chave pessoal
#   nemoclaw_ed25519 / nemoclaw_ed25519.pub    — Nemoclaw
#   clotilde.pem                               — cluster Clotilde (AWS)

Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/lerian_github_key

